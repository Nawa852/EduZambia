{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://pmoxtvuhsupfpfcstlur.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "eduzambia-mcp",
      "version": "0.1.0",
      "title": "EduZambia MCP"
    },
    "tools": [
      {
        "name": "search_courses",
        "title": "Search courses",
        "description": "Search the EduZambia course catalog by title or subject keyword.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Keyword to match against course titles and subjects."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "description": "Max results to return (default 10)."
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_assignments",
        "title": "List my assignments",
        "description": "List the signed-in user's assignments with optional status filter.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "submitted",
                "graded"
              ],
              "description": "Filter by assignment status."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "ask_ai_tutor",
        "title": "Ask BrightSphere AI Tutor",
        "description": "Ask the EduZambia AI tutor a question about the Zambian ECZ curriculum. Returns a plain-text tutor response.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "question": {
              "type": "string",
              "minLength": 1,
              "description": "The student's question."
            },
            "grade": {
              "type": "string",
              "description": "Grade level (e.g. 'Grade 9', 'Grade 12')."
            },
            "subject": {
              "type": "string",
              "description": "Subject area, e.g. 'Mathematics', 'Biology'."
            }
          },
          "required": [
            "question"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
